{
  "openapi": "3.1.1",
  "info": {
    "title": "OTPIQ SMS API",
    "description": ""
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/info": {
      "get": {
        "description": "Retrieve information about the authenticated project including remaining credits and project details.",
        "responses": {
          "200": {
            "description": "Project information retrieved successfully. Response body includes: projectName (string), credit (number).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectInfo"
                },
                "examples": {
                  "success": {
                    "summary": "Successful response",
                    "value": {
                      "projectName": "My SMS Project",
                      "credit": 15000
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/sender-ids": {
      "get": {
        "tags": [
          "Sender IDs"
        ],
        "summary": "Get sender IDs",
        "description": "Retrieve all sender IDs associated with the authenticated project.",
        "operationId": "getSenderIds",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Sender IDs retrieved successfully. Response body includes: success (boolean), data (array of SenderId).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SenderIdsResponse"
                },
                "examples": {
                  "success": {
                    "summary": "Successful response",
                    "value": {
                      "success": true,
                      "data": [
                        {
                          "_id": "507f1f77bcf86cd799439011",
                          "senderId": "OTPIQ",
                          "status": "accepted",
                          "pricePerSms": {
                            "korekTelecom": 80,
                            "asiaCell": 80,
                            "zainIraq": 80,
                            "others": 100
                          }
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/sms": {
      "post": {
        "tags": [
          "SMS"
        ],
        "summary": "Send SMS",
        "description": "Send an SMS message. Supports both verification codes and custom messages with multiple provider options.",
        "operationId": "sendSMS",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "description": "SMS request parameters.\n\nRequired:\n- phoneNumber: International format without + (e.g., 964750123456)\n- smsType: 'verification' or 'custom'\n\nConditional requirements:\n- When smsType = 'verification': verificationCode is required\n- When smsType = 'custom': customMessage and senderId are required\n\nOptional:\n- provider: Choose from multiple options including fallback routes (default: 'auto')\n  - `whatsapp-sms`: Try WhatsApp first, fallback to SMS (recommended)\n  - `telegram-sms`: Try Telegram first, fallback to SMS\n  - `whatsapp-telegram-sms`: Try WhatsApp → Telegram → SMS (maximum delivery success)\n  - `sms`: SMS only\n  - `whatsapp`: WhatsApp only\n  - `telegram`: Telegram only\n- deliveryReport: WebhookConfig for delivery status webhooks",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendSMSRequest"
              },
              "examples": {
                "verification": {
                  "summary": "Send verification code",
                  "value": {
                    "phoneNumber": "964750123456",
                    "smsType": "verification",
                    "verificationCode": "123456",
                    "provider": "whatsapp-sms"
                  }
                },
                "custom": {
                  "summary": "Send custom message",
                  "value": {
                    "phoneNumber": "964750123456",
                    "smsType": "custom",
                    "customMessage": "Your order #12345 has been confirmed. Thank you for your purchase!",
                    "senderId": "OTPIQ",
                    "provider": "sms"
                  }
                },
                "with_webhook": {
                  "summary": "Send SMS with webhook notifications",
                  "value": {
                    "phoneNumber": "964750123456",
                    "smsType": "verification",
                    "verificationCode": "123456",
                    "provider": "whatsapp-sms",
                    "deliveryReport": {
                      "webhookUrl": "https://your-app.com/webhooks/sms-status",
                      "deliveryReportType": "all",
                      "webhookSecret": "your_webhook_secret_123"
                    }
                  }
                },
                "telegram_fallback": {
                  "summary": "Send with Telegram fallback to SMS",
                  "value": {
                    "phoneNumber": "964750123456",
                    "smsType": "verification",
                    "verificationCode": "123456",
                    "provider": "telegram-sms"
                  }
                },
                "maximum_fallback": {
                  "summary": "Send with maximum fallback options",
                  "value": {
                    "phoneNumber": "964750123456",
                    "smsType": "verification",
                    "verificationCode": "123456",
                    "provider": "whatsapp-telegram-sms"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent successfully. Response body includes: message (string), smsId (string), remainingCredit (number), cost (number), canCover (boolean), paymentType ('prepaid' | 'postpaid').",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendSMSResponse"
                },
                "examples": {
                  "success": {
                    "summary": "Successful response",
                    "value": {
                      "message": "SMS task created successfully",
                      "smsId": "sms-1234567890abcdef123456",
                      "remainingCredit": 14800,
                      "cost": 200,
                      "canCover": true,
                      "paymentType": "prepaid"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ValidationError"
                    },
                    {
                      "$ref": "#/components/schemas/InsufficientCreditError"
                    },
                    {
                      "$ref": "#/components/schemas/SpendingThresholdError"
                    },
                    {
                      "$ref": "#/components/schemas/SenderIdError"
                    },
                    {
                      "$ref": "#/components/schemas/TrialModeError"
                    }
                  ]
                },
                "examples": {
                  "validation": {
                    "summary": "Validation error",
                    "value": {
                      "error": "Phone must be a valid number without any spaces or special characters."
                    }
                  },
                  "insufficient_credit": {
                    "summary": "Insufficient credit",
                    "value": {
                      "error": "Insufficient credit, please add more credit",
                      "yourCredit": 100,
                      "requiredCredit": 200,
                      "canCover": false
                    }
                  },
                  "spending_threshold": {
                    "summary": "Spending threshold exceeded",
                    "value": {
                      "error": "Project spending threshold of 10,000 IQD would be exceeded. Current spending: 9,500 IQD",
                      "currentSpending": 9500,
                      "spendingThreshold": 10000,
                      "cost": 200
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitError"
                },
                "examples": {
                  "rate_limit": {
                    "summary": "Rate limit exceeded",
                    "value": {
                      "message": "Rate limit exceeded. Please try again in 8 minutes. Maximum 10 requests allowed per phone number in 10 minutes.",
                      "waitMinutes": 8,
                      "maxRequests": 10,
                      "timeWindowMinutes": 10
                    }
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/sms/track/{smsId}": {
      "get": {
        "tags": [
          "SMS"
        ],
        "summary": "Track SMS",
        "description": "Get the delivery status of a specific SMS message.",
        "operationId": "trackSMS",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "smsId",
            "in": "path",
            "description": "The SMS ID to track",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^sms-[a-f0-9]{24}$",
              "examples": [
                "sms-1234567890abcdef123456"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SMS status retrieved successfully. Response body includes SMSTrackingResponse with fields: smsId, phoneNumber, status, cost, isFinalStatus, lastChannel, channelFlow[].",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SMSTrackingResponse"
                },
                "examples": {
                  "success": {
                    "summary": "Successful response",
                    "value": {
                      "smsId": "sms-1234567890abcdef123456",
                      "phoneNumber": "964750123456",
                      "status": "sent",
                      "cost": 200,
                      "isFinalStatus": false,
                      "lastChannel": "whatsapp",
                      "channelFlow": [
                        {
                          "channel": "whatsapp",
                          "tried": true,
                          "success": true
                        },
                        {
                          "channel": "sms",
                          "tried": false
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "SMS not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                },
                "examples": {
                  "not_found": {
                    "summary": "SMS not found",
                    "value": {
                      "message": "SMS not found"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  }
}